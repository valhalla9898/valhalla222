using './main.bicep'

param location = 'eastus'
param environment = 'prod'
param projectName = 'agentic-iam'
param containerImageName = 'agentic-iam'
param containerImageTag = 'latest'
param vnetAddressPrefix = '10.0.0.0/16'
param subnetAddressPrefix = '10.0.0.0/24'
param postgresqlAdminUser = 'pgadmin'
param postgresqlDatabaseName = 'agentic_iam'
param postgresqlSkuName = 'Standard_B2s'
param redisSkuName = 'Standard'
param redisCapacity = 1
